# ── Kalshi ──────────────────────────────────────────────────────────────────
# Get from: https://kalshi.com/account/api
KALSHI_API_KEY=
KALSHI_API_SECRET=
 
# ── Novig ────────────────────────────────────────────────────────────────────
# Apply at: https://docs.novig.com  (only needed for execution, not reads)
NOVIG_OAUTH_TOKEN=
 
# ── Alerts ───────────────────────────────────────────────────────────────────
# Create a webhook in your Discord server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=
 
# ── Bot behaviour ────────────────────────────────────────────────────────────
# Minimum price gap (0-1) to flag as an opportunity  (default 4%)
MIN_EDGE=0.04
 
# Maximum dollars risked per bet leg
MAX_BET_SIZE=100
 
# Minimum USD liquidity required on each side before flagging
MIN_LIQUIDITY_USD=50
 
# Seconds between full scan cycles
POLL_INTERVAL=10
 
# Fuzzy match confidence required to consider two markets the same event (0-100)
MATCH_THRESHOLD=85
 
# Set to "false" to enable live order execution (leave true until validated!)
DRY_RUN=true
